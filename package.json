{
  "name": "genomics-mcp",
  "version": "0.1.0",
  "description": "MCP server for genomics SNP trait lookup",
  "author": "Borja Nebbal (https://github.com/borjanebbal)",
  "license": "MIT",
  "keywords": [
    "mcp",
    "genomics",
    "snp",
    "genetics",
    "model-context-protocol"
  ],
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc --noEmit",
    "test": "bun test",
    "lint": "bunx @biomejs/biome lint src/",
    "format": "bunx @biomejs/biome format src/ --write",
    "check": "bunx @biomejs/biome check --write src/",
    "check:staged": "bunx @biomejs/biome check --staged --write",
    "inspector": "bunx @modelcontextprotocol/inspector bun src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "typescript": "^5.7.2"
  }
}
